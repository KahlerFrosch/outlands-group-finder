generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id                         String               @id @default(cuid())
  categoryLevel1             String
  categoryLevel2             String?
  categoryLevel3             String?
  description                String               @default("") @db.Text
  available                  Boolean              @default(true)
  requireRoleSelection Boolean                    @default(false)
  requireRedlinePoints Boolean                    @default(false)
  requireChainLinks Boolean                       @default(false)
  voiceChannelListen         Boolean              @default(false)
  voiceChannelSpeak          Boolean              @default(false)
  expiresAt                  DateTime
  createdAt                  DateTime             @default(now())
  members                    GroupMember[]
  applications               GroupApplication[]
  chatMessages               GroupChatMessage[]
}

model GroupMember {
  id        String  @id @default(cuid())
  groupId   String
  group     Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  discordId String
  name      String
  isCreator Boolean @default(false)
  role      String?
  redlinePoints   Int?
  chainLinkSlots  Int?

  @@unique([groupId, discordId])
  @@index([groupId])
}

model GroupApplication {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  discordId String
  name      String
  role      String?
  redlinePoints   Int?
  chainLinkSlots  Int?
  createdAt DateTime @default(now())

  @@unique([groupId, discordId])
  @@index([groupId])
}

model GroupChatMessage {
  id         String   @id @default(cuid())
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  discordId  String
  authorName String
  body       String   @db.Text
  createdAt  DateTime @default(now())

  @@index([groupId, createdAt])
}
