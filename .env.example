# Discord OAuth (create app at https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Database (PostgreSQL – local example below; use Neon/Vercel Postgres URL in production)
# Example local: postgresql://postgres:postgres@localhost:5432/outlands_group_finder
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Pusher (real-time updates across Vercel instances)
# Create an app at https://dashboard.pusher.com/ and fill these in.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=
