# Discord OAuth (create app at https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Database (PostgreSQL – local example below; use Neon/Vercel Postgres URL in production)
# Example local: postgresql://postgres:postgres@localhost:5432/outlands_group_finder
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
