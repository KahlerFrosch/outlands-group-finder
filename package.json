{
  "name": "outlands-group-finder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "db:status:prod": "dotenv -e .env.production -- prisma migrate status"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "pusher": "^5.3.2",
    "pusher-js": "^8.4.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "@types/node": "20.11.19",
    "@types/react": "18.2.57",
    "@types/react-dom": "18.2.19",
    "autoprefixer": "10.4.17",
    "eslint": "8.57.0",
    "postcss": "8.4.35",
    "prisma": "^6.19.2",
    "tailwindcss": "3.4.1",
    "typescript": "^5.9.3"
  }
}
